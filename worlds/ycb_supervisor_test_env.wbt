WorldInfo {
  contactProperties [
    ContactProperties {
      material1 "default"
      material2 "default"
      coulombFriction [
        1.2
      ]
    }
  ]
}
Viewpoint {
  orientation 1 0 -1 3.14
  position 0 0 5.5
  followType "None"
}
TexturedBackground {
}
TexturedBackgroundLight {
  luminosity 1.2
  castShadows FALSE
}
blank_floor {
}
UR5e {
  translation -0.5 0 0
  controller "ur5e_controller"
  toolSlot [
    IntelRealsenseD455 {
      translation 0 -0.03 0.05
      rotation 0 0 1 1.5708
      controller "realsense_controller"
    }
    Pose {
      rotation 0 1 0 1.5707996938995747
      children [
        Robotiq2f140Gripper {
          rotation 1 0 0 -1.5707996938995747
        }
      ]
    }
  ]
}
Robot {
  supervisor TRUE
  controller "ycb_supervisor"
}

